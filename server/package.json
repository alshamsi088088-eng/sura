{
  "name": "sura-codex-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production tsx src/index.ts",
    "postinstall": "prisma generate --schema ../schema.prisma",
    "db:migrate": "prisma migrate dev --name init --schema ../schema.prisma",
    "db:seed": "cross-env NODE_ENV=development tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.4",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.7.2",
    "stripe": "^12.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.1",
    "@types/express": "^4.17.20",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.8",
    "@types/passport-google-oauth20": "^2.0.10",
    "@types/supertest": "^2.0.12",
    "cross-env": "^7.0.3",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "tsx": "^3.12.7",
    "typescript": "^5.5.0",
    "vitest": "^1.4.0"
  }
}