generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_DB_URL")
}

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  password          String?
  role              String     @default("member")
  avatar            String?
  bio               String?
  locale            String     @default("en")
  theme             String     @default("dark")
  verified          Boolean    @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpires DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  articles          Article[]  @relation("ArticleAuthor")
  bookmarks         Bookmark[]
  comments          Comment[]
  novels            Novel[]    @relation("NovelAuthor")
  orders            Order[]
  ratings           Rating[]
  likes             Like[]
  reactions         Reaction[]
  pollVotes         PollVote[]
  communityThreads CommunityThread[]
  notifications    Notification[]
  badges           Badge[]
  follows          Follow[]   @relation("UserFollows")
  following        Follow[]   @relation("UserFollowing")
  notificationSettings NotificationSettings?
  quotes          Quote[]
}

model Article {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String
  content     String
  category    String
  language    String
  readingTime String
  authorName  String
  views       Int        @default(0)
  claps       Int        @default(0)
  featured    Boolean    @default(false)
  publishedAt DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorId    String?
  author      User?      @relation("ArticleAuthor", fields: [authorId], references: [id], onUpdate: NoAction)
  bookmarks   Bookmark[]
  comments    Comment[]
  ratings     Rating[]
  likes      Like[]
}

model Novel {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  coverImage  String
  authorName  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorId    String?
  bookmarks   Bookmark[]
  chapters    Chapter[]
  parts       Part[]
  comments    Comment[]
  author      User?      @relation("NovelAuthor", fields: [authorId], references: [id], onUpdate: NoAction)
  ratings     Rating[]
  likes       Like[]
}

model Part {
  id          String     @id @default(cuid())
  title       String
  number     Int
  novelId    String
  novel      Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chapters   Chapter[]  @relation("PartChapters")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([novelId, number])
}

model Chapter {
  id          String     @id @default(cuid())
  novelId     String
  partId      String?
  title       String
  number      Int
  content     String
  readingTime String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookmarks   Bookmark[]
  novel       Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  part        Part?      @relation("PartChapters", fields: [partId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  comments    Comment[]
  ratings     Rating[]
  likes       Like[]
  polls       Poll[]

  @@unique([novelId, number])
}

model Book {
  id         String      @id @default(cuid())
  title      String
  author     String
  price      Float
  format     String
  summary    String
  coverImage String
  stock      Int
  fileUrl    String?
  previewUrl String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  bookmarks  Bookmark[]
  comments   Comment[]
  orderItems OrderItem[]
  ratings    Rating[]
  likes      Like[]
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  email           String
  subtotal        Float
  total           Float
  discountCode    String?
  discountAmount  Float       @default(0)
  stripeSessionId String?     @unique
  status          String      @default("paid")
  currency        String      @default("usd")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User?       @relation(fields: [userId], references: [id], onUpdate: NoAction)
  items           OrderItem[]
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  bookId          String
  titleSnapshot   String
  priceAtPurchase Float
  quantity        Int      @default(1)
  createdAt       DateTime @default(now())
  book            Book     @relation(fields: [bookId], references: [id], onUpdate: NoAction)
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  approved  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  articleId String?
  novelId   String?
  chapterId String?
  bookId    String?
  communityId String?
  parentId  String?
  article   Article?  @relation(fields: [articleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  book      Book?     @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chapter   Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  novel     Novel?    @relation(fields: [novelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  community CommunityThread? @relation(fields: [communityId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replies   Comment[] @relation("CommentReplies")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Rating {
  id        String   @id @default(cuid())
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  articleId String?
  novelId   String?
  chapterId String?
  bookId    String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  novel     Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, articleId])
  @@unique([userId, bookId])
  @@unique([userId, chapterId])
  @@unique([userId, novelId])
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  articleId String?
  novelId   String?
  chapterId String?
  bookId    String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  novel     Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, articleId])
  @@unique([userId, bookId])
  @@unique([userId, chapterId])
  @@unique([userId, novelId])
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  articleId String?
  novelId   String?
  chapterId String?
  bookId    String?
  communityId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  novel     Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  community CommunityThread? @relation(fields: [communityId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, articleId])
  @@unique([userId, bookId])
  @@unique([userId, chapterId])
  @@unique([userId, novelId])
  @@unique([userId, communityId])
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String
  category  String
  imageUrl  String
  createdAt DateTime @default(now())
}

model TechArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  series      String
  tags        String
  excerpt     String
  code        String
  publishedAt DateTime @default(now())
}

model Coupon {
  id               String    @id @default(cuid())
  code             String    @unique
  type             String    @default("percent")
  value            Float
  active           Boolean   @default(true)
  maxUses          Int?
  usedCount        Int       @default(0)
  minSubtotal      Float?
  startsAt         DateTime?
  endsAt           DateTime?
  perItem          Boolean   @default(false)
  applicableBookId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  author    String
  text      String
  createdAt DateTime @default(now())
}

model Reaction {
  id           String   @id @default(cuid())
  userId       String
  contentId    String
  contentType String
  emoji       String
  createdAt    DateTime  @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, contentId])
}

model Poll {
  id           String   @id @default(cuid())
  contentId    String
  contentType String
  chapterId    String?
  question    String
  type        String   @default("single")
  isAnonymous Boolean  @default(false)
  isPublic    Boolean  @default(true)
  closesAt     DateTime?
  createdBy   String
  createdAt  DateTime  @default(now())
  chapter     Chapter?      @relation(fields: [chapterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  options     PollOption[]
  votes       PollVote[]

  @@unique([contentId, contentType])
}

model PollOption {
  id        String   @id @default(cuid())
  pollId    String
  text      String
  createdAt DateTime @default(now())
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  votes     PollVote[]
}

model PollVote {
  id        String      @id @default(cuid())
  pollId    String
  optionId  String
  userId   String?
  createdAt DateTime    @default(now())
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  option   PollOption  @relation(fields: [optionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user     User?      @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

model CommunityThread {
  id           String   @id @default(cuid())
  authorId     String
  contentId   String?
  contentType String?
  category    String
  title       String
  body        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parentId    String?
  parent      CommunityThread? @relation("ThreadReplies", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replies     CommunityThread[] @relation("ThreadReplies")
  likes       Like[]
  comments    Comment[]
  bookmarks   CommunityBookmark[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type     String
  title    String
  body     String?
  link     String?
  actorId  String?
  actorName String?
  isRead   Boolean  @default(false)
  createdAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([userId, isRead])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt  DateTime @default(now())
  user       User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  following  User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Badge {
  id          String   @id @default(cuid())
  userId      String
  badgeKey    String
  title       String
  description String?
  icon        String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, badgeKey])
  @@index([userId])
}

model ReadingHistory {
  id          String   @id @default(cuid())
  userId      String
  contentType String
  contentId   String
  title       String?
  progress   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, contentType, contentId])
  @@index([userId])
}

model CommunityBookmark {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())
  thread   CommunityThread @relation(fields: [threadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, threadId])
  @@index([userId])
}

model NotificationSettings {
  id          String   @id @default(cuid())
  userId      String   @unique
  likes       Boolean  @default(true)
  comments   Boolean  @default(true)
  replies    Boolean  @default(true)
  reactions  Boolean  @default(true)
  pollVotes  Boolean  @default(true)
  newChapter Boolean  @default(true)
  newArticle Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

model Quote {
  id           String   @id @default(cuid())
  userId       String
  contentId    String
  contentType  String
  selectedText String
  startOffset  Int?
  endOffset   Int?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, contentId, startOffset, endOffset])
  @@index([userId])
  @@index([contentId, contentType])
}
